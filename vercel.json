{
  "builds": [
    {
      "src": "backend/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/buah(.*)", "dest": "backend/server.ts" },
    { "src": "/stats(.*)", "dest": "backend/server.ts" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}